    <TABLE NAME="tool_guardianlink_courseconfig" COMMENT="Per-course GuardianLink policy set by teachers; access-duration limits cascade Admin to course to parent">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="maxgrantdays" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Course cap on delegated-access duration in days; 0 = inherit global admin max"/>
        <FIELD NAME="defaultgrantdays" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Course default grant duration in days; 0 = inherit global default"/>
        <FIELD NAME="allowparentpropose" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" SEQUENCE="false" COMMENT="Whether parents may propose tutors/guardians for this course"/>
        <FIELD NAME="allowteacherproxy" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" SEQUENCE="false"/>
        <FIELD NAME="allowassistedaccess" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Teacher allows governed parent/caregiver assisted (co-presence) login in this course"/>
        <FIELD NAME="allowindependentaccess" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Teacher deems this course safe for independent (unsupervised) learner access subject to parent acknowledgement"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid" UNIQUE="true" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="tool_guardianlink_indack" COMMENT="Parent/guardian acknowledgements allowing a learner independent (unsupervised) access to a course">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="guardianid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Authorised adult who acknowledged"/>
        <FIELD NAME="childid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Learner allowed independent access"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="allowed" SEQUENCE="false" COMMENT="allowed or revoked"/>
        <FIELD NAME="note" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="acknowledgedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="User who recorded the acknowledgement (usually the guardian)"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="uniqack" UNIQUE="true" FIELDS="guardianid,childid,courseid"/>
        <INDEX NAME="childcourse" UNIQUE="false" FIELDS="childid,courseid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="tool_guardianlink_template" COMMENT="Reusable email/message templates with placeholders, sent at appropriate times">
