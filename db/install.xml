<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="admin/tool/guardianlink/db" VERSION="2026063010" COMMENT="GuardianLink Moodle 5.2+ tables" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="tool_guardianlink_reltype" COMMENT="Configurable relationship and support-role definitions">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="shortname" TYPE="char" LENGTH="64" NOTNULL="true" SEQUENCE="false" COMMENT="Stable code such as legal_parent, hostel_warden, tutor"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="category" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="family" SEQUENCE="false" COMMENT="family, care, education, residential, welfare, other"/>
        <FIELD NAME="defaultprofile" TYPE="char" LENGTH="64" NOTNULL="true" DEFAULT="family_basic" SEQUENCE="false"/>
        <FIELD NAME="maydelegate" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="mayholdlegal" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="systemmanaged" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="active" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1" SEQUENCE="false"/>
        <FIELD NAME="sortorder" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="configjson" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="shortname" UNIQUE="true" FIELDS="shortname"/>
        <INDEX NAME="categoryactive" UNIQUE="false" FIELDS="category,active"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="tool_guardianlink_rel" COMMENT="Authorised adult to learner relationships; guardianid means adult user and childid means learner user for compatibility">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="guardianid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Authorised adult user id"/>
        <FIELD NAME="childid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Learner user id"/>
        <FIELD NAME="reltypeid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="reltype" TYPE="char" LENGTH="64" NOTNULL="true" DEFAULT="legal_parent" SEQUENCE="false"/>
        <FIELD NAME="relcategory" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="family" SEQUENCE="false"/>
        <FIELD NAME="legal" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Holder of parental/legal responsibility where applicable"/>
        <FIELD NAME="authoritybasis" TYPE="char" LENGTH="64" NOTNULL="true" DEFAULT="school_record" SEQUENCE="false" COMMENT="Basis such as school_record, court_order, care_order, hostel_record, consent, contract"/>
        <FIELD NAME="authoritystatus" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="verified" SEQUENCE="false" COMMENT="unverified, verified, restricted, disputed, revoked"/>
        <FIELD NAME="confidentiality" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="standard" SEQUENCE="false" COMMENT="standard, restricted, sensitive, safeguarding"/>
        <FIELD NAME="householdkey" TYPE="char" LENGTH="128" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="contactgroupkey" TYPE="char" LENGTH="128" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="16" NOTNULL="true" DEFAULT="pending" SEQUENCE="false"/>
        <FIELD NAME="consentstatus" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="not_required" SEQUENCE="false"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="approvedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="starttime" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="endtime" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="reviewtime" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="lastsynced" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="sourcecode" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false" COMMENT="ERP/SIS/source system"/>
        <FIELD NAME="externalid" TYPE="char" LENGTH="128" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sourcerevision" TYPE="char" LENGTH="128" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="tenantkey" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false" COMMENT="Optional Moodle Workplace or campus tenant key"/>
        <FIELD NAME="restrictionsjson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Machine-readable restrictions, never broad narrative safeguarding notes"/>
        <FIELD NAME="rightsjson" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="notes" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="guardianfk" TYPE="foreign" FIELDS="guardianid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="childfk" TYPE="foreign" FIELDS="childid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="guardianstatus" UNIQUE="false" FIELDS="guardianid,status"/>
        <INDEX NAME="childstatus" UNIQUE="false" FIELDS="childid,status"/>
        <INDEX NAME="reltype" UNIQUE="false" FIELDS="reltype"/>
        <INDEX NAME="authority" UNIQUE="false" FIELDS="authoritystatus,confidentiality"/>
        <INDEX NAME="timelimit" UNIQUE="false" FIELDS="starttime,endtime"/>
        <INDEX NAME="reviewtime" UNIQUE="false" FIELDS="reviewtime"/>
        <INDEX NAME="external" UNIQUE="false" FIELDS="sourcecode,externalid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="tool_guardianlink_scope" COMMENT="Course/category scoped grants for GuardianLink relationships">
