      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="actorchildtime" UNIQUE="false" FIELDS="actorid,childid,timecreated"/>
        <INDEX NAME="childtime" UNIQUE="false" FIELDS="childid,timecreated"/>
